using Gtk 4.0;
using Adw 1;

Gtk.Box root {
  width-request: 860;
  halign: center;
  orientation: vertical;
  Gtk.FlowBox flow {
    homogeneous: true;
    column-spacing: 0;
    row-spacing: 0;
    // TODO: Use brakepoints
    max-children-per-line: 4;
    min-children-per-line: 3;
    selection-mode: none;
    hexpand: true;
    halign: center;
  }
}